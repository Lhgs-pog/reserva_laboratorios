# Copie para .env e ajuste (local Docker ou Cloud SQL / MySQL remoto)
APP_ENV=local

# Banco — local Docker usa mysql; na nuvem use host do Cloud SQL ou MySQL gerenciado
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sistema_labs
DB_USERNAME=root
DB_PASSWORD=root

# Cloud Run + Cloud SQL (nuvem)
# CLOUD_SQL_CONNECTION_NAME=labhub-uniceplac-vini:southamerica-east1:labhub-db

# Google OAuth (opcional — login institucional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://labhub-uniceplac.onrender.com/login_google.php
