# Copie para .env — local (Docker+MySQL) ou produção (Supabase PostgreSQL)
APP_ENV=local

# --- Local Docker (docker compose up) — padrão para desenvolvimento ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sistema_labs
DB_USERNAME=root
DB_PASSWORD=root

# --- Produção Supabase + Fly.io (São Paulo) ---
# DB_CONNECTION=pgsql
# DB_HOST=aws-1-sa-east-1.pooler.supabase.com
# DB_PORT=5432
# DB_SSLMODE=require
# DB_DATABASE=postgres
# DB_USERNAME=postgres.eqawtpbvcqlcemysjkox
# DB_PASSWORD=

# Google OAuth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://labhub-uniceplac-sp.fly.dev/login_google.php

# APP_FAST_PANEL=1 — painel coordenador sem BI/histórico na 1ª carga (mais rápido)
# APP_FAST_PANEL=0 — carrega tudo de uma vez (mais lento)
# APP_FAST_PANEL=1
# APP_URL=https://labhub-uniceplac-sp.fly.dev

# Sessão persistente (sobrevive a deploy no Fly.io)
# SESSION_DRIVER=db
# SESSION_LIFETIME=28800
# REMEMBER_ME_DAYS=30

# --- E-mail (escolha UM provedor) ---
#
# Opção A — Resend (recomendado, API simples, 100 e-mails/dia grátis):
# https://resend.com → API Keys → re_...
# Verifique um domínio (ex: updates.seudominio.com) e use como remetente:
# RESEND_API_KEY=re_...
# MAIL_FROM_ADDRESS=noreply@updates.seudominio.com
# MAIL_FROM_NAME=LabHub UNICEPLAC
#
# Opção B — Brevo SMTP/API:
# Painel Brevo: Configurações → SMTP e API → Chaves SMTP
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=seu_id@smtp-brevo.com
# BREVO_API_KEY=xkeysib-...
# MAIL_SMTP_PASSWORD=xsmtpsib-...
# MAIL_FROM_ADDRESS=remetente_verificado_na_brevo@gmail.com
# MAIL_FROM_NAME=LabHub UNICEPLAC
