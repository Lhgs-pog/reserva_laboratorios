# Supabase — projeto labhub-uniceplac (PostgreSQL na nuvem)
# Dashboard: https://supabase.com/dashboard/project/vhhwpiabrclicwuvedqw
SUPABASE_URL=https://vhhwpiabrclicwuvedqw.supabase.co
# Copie a anon key e service role em: Project Settings → API
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta Postgres (Settings → Database → Connection string)
# O app PHP atual usa MySQL; para usar Supabase precisa adaptar PDO para PostgreSQL.
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
